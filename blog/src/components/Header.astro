---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">
			<img src="/manu_transparent.png" alt="" class="logo" />
			{SITE_TITLE}
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog.html">Archives</HeaderLink>
			<HeaderLink href="/tags.html">Tags</HeaderLink>
			<HeaderLink href="/about.html">About</HeaderLink>
			<a href="/search.html" class="search-link" aria-label="Search">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="11" cy="11" r="8" />
					<line x1="21" y1="21" x2="16.65" y2="16.65" />
				</svg>
			</a>
		</div>
		<div class="social-links">
			<a href="https://bsky.app/profile/docrostov.bsky.social" target="_blank" aria-label="Bluesky">
				<img src="/bsky.svg" alt="Bluesky" width="20" height="20" class="social-icon" />
			</a>
			<a href="https://twitter.com/docrostov/" target="_blank" aria-label="Twitter">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20">
					<path fill="currentColor" d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"/>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: rgb(var(--black));
		border-bottom: 3px solid var(--accent);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		height: 56px;
	}

	.site-title {
		display: flex;
		align-items: center;
		gap: 0.5em;
		font-family: 'Inter', system-ui, sans-serif;
		font-weight: 600;
		font-size: 1em;
		letter-spacing: -0.01em;
		color: #f5f2ed;
		text-decoration: none;
		white-space: nowrap;
	}

	.site-title:hover {
		color: #fff;
	}

	.logo {
		height: 28px;
		width: auto;
		opacity: 0.85;
		border-radius: 0;
	}

	.internal-links {
		display: flex;
		gap: 0.25em;
	}

	.internal-links a {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.875em;
		font-weight: 500;
		padding: 0.4em 0.75em;
		color: #c8c3bb;
		text-decoration: none;
		border-radius: 4px;
		transition: color 0.15s, background 0.15s;
	}

	.internal-links a:hover,
	.internal-links a.active {
		color: #f5f2ed;
		background: rgba(255,255,255,0.08);
	}

	.search-link {
		color: #c8c3bb;
		text-decoration: none;
		display: flex;
		align-items: center;
		padding: 0.4em 0.5em;
		border-radius: 4px;
		transition: color 0.15s;
	}

	.search-link:hover {
		color: #f5f2ed;
	}

	.social-links {
		display: flex;
		align-items: center;
		gap: 0.75em;
	}

	.social-links a {
		color: #c8c3bb;
		text-decoration: none;
		display: flex;
		align-items: center;
		transition: color 0.15s, opacity 0.15s;
	}

	.social-links a:hover {
		color: #f5f2ed;
	}

	.social-icon {
		opacity: 0.75;
		filter: brightness(0) invert(1);
	}

	.social-links a:hover .social-icon {
		opacity: 1;
	}

	@media (max-width: 720px) {
		.social-links { display: none; }
		.internal-links { display: none; }
		header { padding: 0 1em; }
	}
</style>
