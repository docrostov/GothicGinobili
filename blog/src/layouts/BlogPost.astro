---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { AUTHORS } from '../data/authors';

type Props = Omit<CollectionEntry<'blog'>['data'], 'postId' | 'slug'> & {
	postId?: number;
	slug?: string;
	prevPost?: CollectionEntry<'blog'> | null;
	nextPost?: CollectionEntry<'blog'> | null;
};

const { title, author, date, category, heroImage, heroImageCredit, prevPost, nextPost } = Astro.props;
const authorSlug = author.toLowerCase().replace(/['']/g, '').replace(/[^a-z0-9]+/g, '-').replace(/-+$/, '');
const authorPhoto = AUTHORS[authorSlug]?.photo;
---

<html lang="en">
	<head>
		<BaseHead title={`${title} — Gothic Ginobili`} description={`${category} — Gothic Ginobili`} />
	</head>
	<body>
		<Header />

		{/* Floating prev/next — desktop only */}
		<nav class="post-nav-float" aria-label="Post navigation">
			<div class="nav-next">
				{nextPost && (
					<a href={`/${nextPost.data.slug}.html`}>
						<span class="nav-eyebrow">{`← Next`}</span>
						<span class="nav-label">{nextPost.data.title}</span>
						<span class="nav-meta"><FormattedDate date={nextPost.data.date} /></span>
					</a>
				)}
			</div>
			<div class="nav-prev">
				{prevPost && (
					<a href={`/${prevPost.data.slug}.html`}>
						<span class="nav-eyebrow">{`Previous →`}</span>
						<span class="nav-label">{prevPost.data.title}</span>
						<span class="nav-meta"><FormattedDate date={prevPost.data.date} /></span>
					</a>
				)}
			</div>
		</nav>

		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<img src={heroImage} alt={heroImageCredit ?? ''} />
						{heroImageCredit && (
							<p class="hero-credit">{heroImageCredit}</p>
						)}
					</div>
				)}
				<div class="post-header">
					<h1>{title}</h1>
					<div class="post-meta">
						<span class="post-meta-text">
							<FormattedDate date={date} /> &mdash;
							<a href={`/category/${category.toLowerCase().replace(/['']/g, '').replace(/[^a-z0-9]+/g, '-').replace(/-+$/, '')}.html`}>{category}</a>
						</span>
						<a href={`/author/${authorSlug}.html`} class="author-byline">
							{authorPhoto && (
								<img
									src={authorPhoto}
									alt={author}
									width="28"
									height="28"
									style="width:28px;height:28px;border-radius:50%;object-fit:cover;border:1px solid rgb(229,232,240);display:inline-block;vertical-align:middle;"
									onerror="this.style.display='none'"
								/>
							)}
							<span>{author}</span>
						</a>
					</div>
					<hr />
				</div>
				<div class="prose">
					<slot />
				</div>
			</article>

			{/* Mobile prev/next — static, at bottom of content */}
			<nav class="post-nav-mobile" aria-label="Post navigation">
				{prevPost && (
					<a href={`/${prevPost.data.slug}.html`} class="mobile-prev">
						← <span>{prevPost.data.title}</span>
					</a>
				)}
				{nextPost && (
					<a href={`/${nextPost.data.slug}.html`} class="mobile-next">
						<span>{nextPost.data.title}</span> →
					</a>
				)}
			</nav>
		</main>

		<Footer />
	</body>
</html>

<style>
	.post-header {
		margin-bottom: 0.5em;
	}

	.post-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.8em;
		color: rgb(var(--gray));
		margin: 0 0 0.6em 0;
		letter-spacing: 0.01em;
	}

	.post-meta-text a {
		color: rgb(var(--gray));
		text-decoration: none;
	}

	.post-meta-text a:hover {
		color: var(--accent);
	}

	.author-byline {
		display: flex;
		align-items: center;
		gap: 0.4em;
		color: rgb(var(--gray));
		text-decoration: none;
		flex-shrink: 0;
	}

	.author-byline:hover {
		color: var(--accent);
	}

	h1 {
		margin: 0 0 0.5em 0;
		font-size: 2.2em;
		line-height: 1.2;
	}

	.post-header hr {
		border: none;
		border-top: 3px solid var(--accent);
		margin: 1em 0 0 0;
	}

	.hero-image {
		margin: -3em -1em 2em -1em;
	}

	.hero-image img {
		width: 100%;
		height: 400px;
		object-fit: cover;
		border-radius: 0;
		display: block;
	}

	.hero-credit {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.75em;
		color: rgb(var(--gray));
		text-align: right;
		margin: 0.4em 0 0 0;
		font-style: italic;
	}

	.prose {
		max-width: 100%;
	}

	/* ── Floating nav (desktop) ── */
	.post-nav-float {
		display: none;
	}

	@media (min-width: 1300px) {
		.post-nav-float {
			display: flex;
			position: fixed;
			top: 72px; /* clears the 56px header + breathing room */
			left: 0;
			right: 0;
			pointer-events: none;
			padding: 0 1rem;
			justify-content: space-between;
			z-index: 50;
		}

		.nav-prev,
		.nav-next {
			pointer-events: all;
			width: 160px;
		}

		.nav-prev a,
		.nav-next a {
			display: flex;
			flex-direction: column;
			gap: 0.3em;
			padding: 0.85em 1em;
			background: var(--bg);
			border: 1px solid rgb(var(--gray-light));
			border-radius: 6px;
			text-decoration: none;
			color: inherit;
			font-family: 'Inter', system-ui, sans-serif;
			line-height: 1.3;
			transition: border-color 0.15s;
		}

		.nav-prev a:hover,
		.nav-next a:hover {
			border-color: var(--accent);
		}

		.nav-eyebrow {
			font-size: 0.68em;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: var(--accent);
		}

		.nav-label {
			font-size: 0.8em;
			color: rgb(var(--black));
			display: -webkit-box;
			-webkit-line-clamp: 3;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}

		.nav-meta {
			font-size: 0.72em;
			color: rgb(var(--gray));
		}
	}

	/* ── Static nav (mobile) ── */
	.post-nav-mobile {
		display: flex;
		justify-content: space-between;
		gap: 1em;
		margin-top: 3em;
		padding-top: 1.5em;
		border-top: 1px solid rgb(var(--gray-light));
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.85em;
	}

	.post-nav-mobile a {
		color: rgb(var(--gray));
		text-decoration: none;
		max-width: 45%;
		line-height: 1.4;
	}

	.post-nav-mobile a:hover {
		color: var(--accent);
	}

	.mobile-next {
		text-align: right;
		margin-left: auto;
	}

	@media (min-width: 1100px) {
		.post-nav-mobile {
			display: none;
		}
	}
</style>
